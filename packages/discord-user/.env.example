# Your personal Discord USER token (NOT a bot token).
# How to get it (one of):
#   1) Open https://discord.com/app in a browser
#   2) DevTools (Cmd+Opt+I) -> Network tab
#   3) Click any channel -> watch for requests to discord.com/api/...
#   4) Click a request -> Headers -> Request Headers -> copy the "Authorization" value
# Treat this token like a password. Anyone with it can read/post as you.
DISCORD_USER_TOKEN=

# Optional: default guild (server) ID. When set, tools that take guildId can omit it.
DISCORD_USER_DEFAULT_GUILD=
